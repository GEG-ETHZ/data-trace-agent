# -----------------------------------------------------------------------------
# Environment Variables (.env.example) — Data Trace Agent
#
# Copy this file to .env and fill in the values for your environment.
# This file is loaded by the Makefile and used for both local dev and deployment.
#
# DO NOT COMMIT .env TO VERSION CONTROL.
# -----------------------------------------------------------------------------

# --- GCP Configuration ---

# Purpose: The Google Cloud project ID where the agent is deployed and resources are located.
# How to get: Find it on the dashboard of your Google Cloud Console.
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>

# Purpose: The Google Cloud region where the Vertex AI Agent Engine is deployed.
# How to get: Choose a region that supports Vertex AI, e.g., "europe-west1".
GOOGLE_CLOUD_LOCATION=europe-west1

# Purpose: A GCS bucket used by Agent Engine to store code and artifacts during deployment.
# How to get: Create a new bucket in the Google Cloud Console in the same project.
GCS_STAGING_BUCKET=<your-gcs-bucket-for-agent-engine-artefacts>

# Purpose: API key for authenticating with Google Cloud services during local development.
# How to get: Create one in the "APIs & Services > Credentials" section of the Cloud Console.
GOOGLE_API_KEY=<your-google-api-key>


# --- Agent Engine Configuration ---

# Purpose: The service account that the deployed agent uses to access other GCP services.
# How to get: This is automatically created and configured by running `make setup-gcp`.
AGENT_ENGINE_SERVICE_ACCOUNT=data-trace-agent-sa@<your-gcp-project-id>.iam.gserviceaccount.com

# Purpose: The unique identifier for the deployed agent resource in Vertex AI.
# How to get: This is automatically generated and saved to `.agent_engine_resource` after the first successful deployment.
# AGENT_ENGINE_RESOURCE_NAME="projects/.../locations/.../agentEngines/..."


# --- Git Authentication (for deployed agent) ---

# Purpose: The name of the secret in Google Secret Manager that holds the Git PAT.
# How to get: Run `make upload-secret <secret-name> <path-to-pat-file>`.
GIT_AUTH_TOKEN_SECRET=gitlab-pat  # pragma: allowlist secret

# Purpose: The hostname of your Git provider (e.g., "gitlab.com", "github.com").
# How to get: This is the domain you use to access your Git repository.
GIT_AUTH_HOST=gitlab.com

# Purpose: The username to use with the PAT. For GitLab/GitHub, this is usually "oauth2".
GIT_AUTH_USERNAME=data-trace-agent  # deploy token name; use oauth2 for PAT

# Purpose: The full HTTPS URL to the repository that DVC needs to clone at runtime.
# How to get: Copy the HTTPS clone URL from your Git provider.
REPO_URL=https://gitlab.com/your-repo/...


# --- Model Configuration ---

# Purpose: Specifies which LLM provider to use (`google`, `anthropic`, `openai`, `litellm`).
# How to get: Set to "google" to use Gemini 2.5 Pro (default).
MODEL_PROVIDER=google

# --- Optional: API Keys for other LLM Providers ---
# ANTHROPIC_API_KEY="<your-anthropic-api-key>"
# OPENAI_API_KEY="<your-openai-api-key>"
# LITELLM_MODEL="<huggingface/model-name>" # Required only if MODEL_PROVIDER="litellm"

# --- Optional: DVC Configuration ---
# Purpose: Provides DVC credentials for non-GCS remotes (e.g., WebDAV, SSH) at runtime.
# How to get: Paste the contents of your local DVC config file (`.dvc/config.local`).
# DVC_CONFIG_LOCAL="[core]\nremote = myremote\n[remote \"myremote\"]\nurl = webdav://..."
GIT_AUTH_TOKEN_SECRET=  # pragma: allowlist secret

# Name of the secret in Secret Manager holding the git token
# GIT_AUTH_TOKEN_SECRET=git-auth-token

# ============================================================================
# Agent Engine Configuration (Optional)
# ============================================================================

# Resource name of an existing Agent Engine to update
# Leave empty to create a new agent on deployment
# Format: projects/{project}/locations/{location}/agentEngines/{id}
# AGENT_ENGINE_RESOURCE_NAME=

# ============================================================================
# Tool Integrations (Optional)
# ============================================================================

# SerpAPI key for web search functionality
# Get one at: https://serpapi.com
# Leave empty to use stub search results
# SERPAPI_API_KEY=
